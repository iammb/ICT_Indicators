//@version=6
// ICT NAS100 - Multi-Timeframe Bias & Entry Signals
// Implements the top-down ICT model from ICT_NAS100_Complete_Strategy.md:
//   4H  : FVG mitigation -> rejection -> MSS  => bias (Bullish / Bearish / Neutral)
//   15M : order-flow direction + mitigation of the 15M FVG in the trade direction
//   1M  : Market Structure Shift (non-negotiable) + 1M FVG as the entry trigger
//   Extras: NY morning session (09:30-13:00 ET), liquidity sweep required before
//           every entry, neutral-4H structure fallback gated by a daily-200-SMA
//           regime guard (long above / short below - insurance against a downtrend,
//           ~free on the bull sample), price-scaled swing-based stops (the point
//           floor/cap scale with price so the model is portable across price levels
//           and instruments), entry/SL/TP plan drawn at 2R.
//   Win-rate tuning (backtested NQ 1-min 2022-2025): require FRESH 15M FVG
//   mitigation (<=5 bars, not up to 40) and enter only on a FULL FILL through
//   the 1M FVG (entryFrac=1.0, not a first-touch tap) - together these took the
//   baseline 43.1% win / PF 1.47 to ~48% win / PF 1.84.
//   Session (default 09:30-13:00 ET): the edge is an AM/lunch-liquidity effect.
//   The morning-only window is the quality peak - 52.8% win, PF 2.15, avgR +0.54,
//   -6R max drawdown - and holds independently in every year tested (2023 PF 2.23,
//   2024 2.29, 2025 1.91). Extending to the full cash session (09:30-16:00) adds
//   trade frequency but the 13:00-16:00 block runs at only PF 1.18 / avgR +0.10,
//   dragging the blended result to 47.7% win / PF 1.73 and doubling drawdown to
//   -8R - most of the apparent 2025 "decay" was really just afternoon trades.
//   Widen the kill-zone session input to 0930-1400 for more total R at PF ~1.99,
//   or 0930-1600 for maximum frequency at the lowest per-trade quality.
//   Out-of-sample check (anchored walk-forward, levers fit on train only): both
//   OOS folds stayed net profitable (test-2024 PF 1.62, test-2025 PF 1.33) and
//   the optimiser re-picked fresh 15M mitigation every fold - the edge survives
//   unseen data, but expect live PF ~1.3-1.6, below the in-sample headline.
// Designed to run on a 1-minute NAS100 chart. By default HTF values come from
// CONFIRMED 4H/15M bars only (no repaint - matches the backtest) and signals
// confirm on bar close. Signals are confluence reads, not automated trade advice.
indicator("ICT NAS100 - Bias & Signals", "ICT NAS100", overlay = true, max_boxes_count = 250, max_labels_count = 100, max_lines_count = 300)

//------------------------------------------------------------------
// Inputs
//------------------------------------------------------------------
grpTF = "Timeframes"
tfBias = input.timeframe("240", "Bias timeframe (4H)", group = grpTF)
tfFlow = input.timeframe("15", "Order-flow timeframe (15M)", group = grpTF)

grpST = "Structure & FVG"
pivBias   = input.int(3, "4H swing pivot length", minval = 1, group = grpST)
pivFlow   = input.int(3, "15M swing pivot length", minval = 1, group = grpST)
pivChart  = input.int(3, "Chart (1M) swing pivot length", minval = 1, group = grpST)
mssMaxAge = input.int(30, "Max chart bars since 1M MSS", minval = 1, group = grpST)
mitMaxAge = input.int(5, "Max 15M bars since 15M FVG mitigation", minval = 1, group = grpST, tooltip = "Backtest: fresh mitigation (<=5 bars = <=75min) beat stale mitigation (up to 40 bars = 10hrs) by a wide margin - 46.9% win / PF 1.73 vs 43.1% win / PF 1.47 - acting on the FVG reaction NOW is a materially stronger setup than reacting to a tap from hours ago.")
sweepLen  = input.int(20, "Liquidity sweep lookback (chart bars)", minval = 2, group = grpST)
revMaxAge = input.int(60, "Max chart bars since sweep / 4H touch (reversals)", minval = 1, group = grpST)

grpKZ = "Kill zone"
useKZ  = input.bool(true, "Require NY morning session (09:30-13:00 ET)", group = grpKZ, tooltip = "Backtest (NQ 2022-2025): the edge is an AM/lunch-liquidity effect and decays sharply after midday. Morning-only 09:30-13:00 (the default here) is the quality peak - 52.8% win, PF 2.15, avgR +0.54, -6R drawdown - and holds in every year (2023 PF 2.23, 2024 2.29, 2025 1.91). 0930-1400 adds total R at PF ~1.99. The full 0930-1600 cash session keeps a bit more raw R but the 13:00-16:00 block alone runs at only PF 1.18 / avgR +0.10, cutting blended quality to PF 1.73 and doubling drawdown to -8R. Most of the apparent 2025 decline was afternoon trades, not the core signal.")
kzSess = input.session("0930-1300", "Kill zone session (ET)", group = grpKZ)
showKZ = input.bool(true, "Shade kill zone", group = grpKZ)

grpTP = "Trade plan (backtested: fresh mitigation + full-fill entry, 09:30-13:00 session, 52.8% win, PF 2.15)"
useRev   = input.bool(false, "Allow neutral-bias reversal setups (lost money in backtest)", group = grpTP)
sweepAll = input.bool(true, "Require liquidity sweep before every entry (ICT)", group = grpTP)
neutralMode = input.string("4H structure", "When 4H bias is neutral", options = ["Stand aside", "4H structure", "15M flow"], group = grpTP, tooltip = "4H FVG bias is neutral ~40% of the time. '4H structure' falls back to plain 4H market structure direction; '15M flow' defers to the 15M order flow; 'Stand aside' takes no trades (strictest, highest PF).")
neutralLongOnly = input.bool(true, "Neutral fallback: longs only (when regime guard off)", group = grpTP, tooltip = "Backtest (NQ 2022-2025): neutral-4H-bias SHORTS lost money (29.7% win, PF 0.82) while neutral-4H-bias LONGS were the best-performing bucket (47.3% win, PF 1.67) - the index trended up over the test period. ON restricts the fallback above to longs; neutral-bias shorts stand aside and require an actual bearish 4H FVG bias instead. Turn OFF to apply the fallback symmetrically to both directions. IGNORED when the regime guard below is ON (the guard supersedes it).")
useRegime = input.bool(true, "Regime guard: neutral fallback follows daily trend", group = grpTP, tooltip = "The static 'longs only' neutral fallback is fit to a 2022-2025 uptrend and would lean long into a downtrend - the strategy's main hidden risk, since the whole backtest is a bull market. ON replaces it with a regime-following rule: take the neutral-4H fallback LONG only when the daily close is above its SMA, SHORT only when below. Insurance, not optimisation - it is ~free on the bull sample (+3R, 305->311 trades, PF 2.15->2.14, drawdown unchanged) because regime was 'down' only 9% of days, and on those down-days it correctly switched the fallback to short. It CANNOT be validated for a sustained bear market (none exists in the data); justified by mechanism + costing nothing in-sample. Explicit bullish/bearish 4H FVG-bias trades are NEVER gated by this - only the discretionary neutral fallback.")
regimeMaLen = input.int(200, "Regime SMA length (daily bars)", minval = 20, group = grpTP, tooltip = "Length of the daily SMA that defines up vs down regime for the guard above. 200 = the classic bull/bear line. Uses the last CONFIRMED daily bar (no repaint); before enough history exists the regime defaults to 'up'.")
dispMult = input.float(0.0, "Min displacement body (x ATR14, 0 = off)", minval = 0, step = 0.25, group = grpTP)
rrTarget = input.float(2.0, "Take-profit target (R multiple)", minval = 0.25, step = 0.25, group = grpTP)
swingSL  = input.bool(true, "Stop beyond MSS swing (not just FVG)", group = grpTP)
slBuf    = input.float(2.0, "Stop buffer (points @ ref price)", minval = 0, step = 0.5, group = grpTP)
maxRisk  = input.float(55, "Max stop distance (points @ ref price, 0 = off)", minval = 0, step = 5, group = grpTP, tooltip = "If the swing-based stop is further than this, the setup is skipped. Backtest: wide-stop setups were net losers; caps of 45-70 pts all tested well. When 'scale stops by price' is on, this is the distance at the reference price and scales with the current price.")
minRisk  = input.float(20, "Min stop distance (points @ ref price, 0 = off)", minval = 0, step = 1, group = grpTP, tooltip = "Stops tighter than this are widened to the floor, protecting against spread/noise on very small 1M FVGs. When 'scale stops by price' is on, this is the distance at the reference price and scales with the current price.")
useVolStop = input.bool(true, "Scale stops by price (volatility-portable)", group = grpTP, tooltip = "The stop floor/cap/buffer above are absolute points, calibrated to NQ at ~20k. ON multiplies them by (price / reference price) so they stay a constant PERCENT of price - the strategy then works at any price level or instrument without recalibration. Validated: neutral-to-better on NQ 2022-2025 (+167->+176R, PF 2.14->2.25), and it removes the price-scale distortion that force-closed 56% of trades in the 2008-2020 out-of-sample test (there, fixed points -> % of price took +144R/PF1.44 to +302R/PF1.57 and made every one of 13 unseen years profitable). OFF = fixed absolute points (original behaviour).")
refPrice = input.float(20000, "Reference price for stop scaling", minval = 1, group = grpTP, tooltip = "The price at which the point distances above are taken literally (NQ's ~2022-2025 median). Stops scale linearly from here: at 2x this price a 20-pt floor becomes 40 pt (same %), at half it becomes 10 pt. Only used when 'scale stops by price' is on.")
entryFrac = input.float(1.0, "Entry depth into 1M FVG (0=near edge, 1=full fill)", minval = 0, maxval = 1, step = 0.25, group = grpTP, tooltip = "Backtest: waiting for price to trade all the way through the 1M FVG (1.0) instead of just tagging the near edge (0) raised win rate from 43.1% to 46.4% on its own (PF 1.47 -> 1.66), with MORE total return from fewer trades. 0.5 = enter at the FVG midpoint (ICT 'CE'). Combined with the mitigation-freshness change above: ~48% win, PF 1.84.")
dowFilter = input.bool(false, "Trade Tue/Fri only (aggressive, off by default)", group = grpTP, tooltip = "OPTIONAL and less robust than the settings above: restricting entries to Tuesday and Friday nominally pushed win rate to 51.5% in backtest, but on only 3 years of data with one of those years landing under 50% - a calendar effect is a weaker, less trustworthy edge than the fresh-mitigation / full-fill-entry logic. Off by default; enable only if you understand and accept that risk.")
showPlan = input.bool(true, "Draw entry / SL / TP on signal", group = grpTP)

grpEx = "Signal integrity"
htfConfirmed = input.bool(true, "Use confirmed HTF bars only (no repaint)", group = grpEx, tooltip = "ON: 4H/15M values come from fully closed bars, exactly like the backtest - live signals never repaint. OFF: HTF values update with the forming bar - more responsive but signals can appear and later vanish.")
confirmBars  = input.bool(true, "Confirm signals on bar close", group = grpEx, tooltip = "ON: BUY/SELL fires only when the 1m bar closes (no intrabar flicker; set alerts to 'Once per bar'). OFF: fires intrabar on the first tick that taps the FVG.")

grpVis = "Visuals"
showTable    = input.bool(true, "Show status table", group = grpVis)
showEntryFvg = input.bool(true, "Draw 1M entry FVGs", group = grpVis)
showZones    = input.bool(true, "Draw active 4H / 15M FVG zones", group = grpVis)

//------------------------------------------------------------------
// 4H bias engine: mitigation -> rejection -> MSS = confirmed bias
//------------------------------------------------------------------
biasEngine(int pivLen) =>
    newBull = low > high[2]
    newBear = high < low[2]
    // rolling high/low stand in for "the swing to break" for MSS confirmation -
    // an approximation, not a confirmed ta.pivothigh/pivotlow like the 15M/1M engines use
    hh = ta.highest(high, pivLen * 2 + 1)
    ll = ta.lowest(low, pivLen * 2 + 1)

    var float bullTop = na
    var float bullBot = na
    var bool  bullMit = false
    var bool  bullRej = false
    var float bullTrig = na
    var float bearTop = na
    var float bearBot = na
    var bool  bearMit = false
    var bool  bearRej = false
    var float bearTrig = na
    var int   bias = 0

    if newBull
        bullTop := low
        bullBot := high[2]
        bullMit := false
        bullRej := false
        bullTrig := na
    if newBear
        bearTop := low[2]
        bearBot := high
        bearMit := false
        bearRej := false
        bearTrig := na

    if not na(bullTop)
        if close < bullBot
            bullTop := na
            bullBot := na
            bullMit := false
            bullRej := false
            if bias == 1
                bias := 0
        else
            if not bullMit and low <= bullTop
                bullMit := true
                bullTrig := hh[1]
            if bullMit and not bullRej and close > bullTop
                bullRej := true
            if bullMit and bullRej and not na(bullTrig) and close > bullTrig
                bias := 1

    if not na(bearTop)
        if close > bearTop
            bearTop := na
            bearBot := na
            bearMit := false
            bearRej := false
            if bias == -1
                bias := 0
        else
            if not bearMit and high >= bearBot
                bearMit := true
                bearTrig := ll[1]
            if bearMit and not bearRej and close < bearBot
                bearRej := true
            if bearMit and bearRej and not na(bearTrig) and close < bearTrig
                bias := -1

    [bias, bullTop, bullBot, bearTop, bearBot]

//------------------------------------------------------------------
// 15M order-flow engine: MSS-based flow + FVG zones with mitigation age
//------------------------------------------------------------------
flowEngine(int pivLen) =>
    ph = ta.pivothigh(high, pivLen, pivLen)
    pl = ta.pivotlow(low, pivLen, pivLen)
    var float lastPh = na
    var float lastPl = na
    if not na(ph)
        lastPh := ph
    if not na(pl)
        lastPl := pl
    var int flow = 0
    if not na(lastPh) and close > lastPh
        flow := 1
        lastPh := na
    if not na(lastPl) and close < lastPl
        flow := -1
        lastPl := na

    newBull = low > high[2]
    newBear = high < low[2]
    var float bullTop = na
    var float bullBot = na
    var int   bullMitAge = -1
    var float bearTop = na
    var float bearBot = na
    var int   bearMitAge = -1

    if newBull
        bullTop := low
        bullBot := high[2]
        bullMitAge := -1
    if newBear
        bearTop := low[2]
        bearBot := high
        bearMitAge := -1

    if not na(bullTop)
        if close < bullBot
            bullTop := na
            bullBot := na
            bullMitAge := -1
        else if bullMitAge < 0
            if low <= bullTop
                bullMitAge := 0
        else
            bullMitAge += 1

    if not na(bearTop)
        if close > bearTop
            bearTop := na
            bearBot := na
            bearMitAge := -1
        else if bearMitAge < 0
            if high >= bearBot
                bearMitAge := 0
        else
            bearMitAge += 1

    [flow, bullTop, bullBot, bullMitAge, bearTop, bearBot, bearMitAge]

//------------------------------------------------------------------
// Higher-timeframe requests
// htfConfirmed ON: offset 1 + lookahead_on = last fully closed HTF bar on
// both historical and realtime bars (canonical non-repainting pattern).
//------------------------------------------------------------------
flowEngineC(int pivLen) =>
    [f, bt, bb, ba, st, sb, sa] = flowEngine(pivLen)
    [f[1], bt[1], bb[1], ba[1], st[1], sb[1], sa[1]]

// combined 4H reader: MSS-confirmed bias (mitigation -> rejection -> MSS) plus a
// plain pivot-break structure direction, reusing the 15M flow engine's logic, for
// the neutral-bias fallback below. One HTF request instead of two per variant.
biasStructEngine(int pivLen) =>
    [bias, bullTop, bullBot, bearTop, bearBot] = biasEngine(pivLen)
    [structDir, flowBt, flowBb, flowBa, flowSt, flowSb, flowSa] = flowEngine(pivLen)
    [bias, bullTop, bullBot, bearTop, bearBot, structDir]

biasStructEngineC(int pivLen) =>
    [bias, bullTop, bullBot, bearTop, bearBot, structDir] = biasStructEngine(pivLen)
    [bias[1], bullTop[1], bullBot[1], bearTop[1], bearBot[1], structDir[1]]

// confirmed variant: offset 1 + lookahead_on = last fully closed HTF bar
// live variant: default request = updates with the forming HTF bar
[h4BiasC, h4BullTopC, h4BullBotC, h4BearTopC, h4BearBotC, h4StructC] = request.security(syminfo.tickerid, tfBias, biasStructEngineC(pivBias), lookahead = barmerge.lookahead_on)
[h4BiasL, h4BullTopL, h4BullBotL, h4BearTopL, h4BearBotL, h4StructL] = request.security(syminfo.tickerid, tfBias, biasStructEngine(pivBias))
[m15FlowC, m15BullTopC, m15BullBotC, m15BullMitAgeC, m15BearTopC, m15BearBotC, m15BearMitAgeC] = request.security(syminfo.tickerid, tfFlow, flowEngineC(pivFlow), lookahead = barmerge.lookahead_on)
[m15FlowL, m15BullTopL, m15BullBotL, m15BullMitAgeL, m15BearTopL, m15BearBotL, m15BearMitAgeL] = request.security(syminfo.tickerid, tfFlow, flowEngine(pivFlow))

h4Bias    = htfConfirmed ? h4BiasC : h4BiasL
h4BullTop = htfConfirmed ? h4BullTopC : h4BullTopL
h4BullBot = htfConfirmed ? h4BullBotC : h4BullBotL
h4BearTop = htfConfirmed ? h4BearTopC : h4BearTopL
h4BearBot = htfConfirmed ? h4BearBotC : h4BearBotL
m15Flow       = htfConfirmed ? m15FlowC : m15FlowL
m15BullTop    = htfConfirmed ? m15BullTopC : m15BullTopL
m15BullBot    = htfConfirmed ? m15BullBotC : m15BullBotL
m15BullMitAge = htfConfirmed ? m15BullMitAgeC : m15BullMitAgeL
m15BearTop    = htfConfirmed ? m15BearTopC : m15BearTopL
m15BearBot    = htfConfirmed ? m15BearBotC : m15BearBotL
m15BearMitAge = htfConfirmed ? m15BearMitAgeC : m15BearMitAgeL
h4Struct = htfConfirmed ? h4StructC : h4StructL

// Daily trend regime for the neutral-fallback guard: is the last CONFIRMED daily
// close above its SMA? offset [1] + lookahead_on = last fully closed daily bar (no
// repaint, matches the backtest). Warmup (SMA not yet available) defaults to 'up'.
[regimeMa, regimeClose] = request.security(syminfo.tickerid, "D", [ta.sma(close, regimeMaLen)[1], close[1]], lookahead = barmerge.lookahead_on)
regimeUp = na(regimeMa) or regimeClose >= regimeMa

//------------------------------------------------------------------
// Chart (1M) structure: Market Structure Shift
//------------------------------------------------------------------
phC = ta.pivothigh(high, pivChart, pivChart)
plC = ta.pivotlow(low, pivChart, pivChart)
var float lastPhC = na
var float lastPlC = na
// used later as the stop-loss swing reference (slPlanL/slPlanS) - note these never
// expire, so a stale swing from well before the current setup can still anchor the stop
var float swingHiVal = na
var float swingLoVal = na
if not na(phC)
    lastPhC := phC
    swingHiVal := phC
if not na(plC)
    lastPlC := plC
    swingLoVal := plC
var int mssDir = 0
var int mssBar = na
if not na(lastPhC) and close > lastPhC
    mssDir := 1
    mssBar := bar_index
    lastPhC := na
if not na(lastPlC) and close < lastPlC
    mssDir := -1
    mssBar := bar_index
    lastPlC := na
mssRecent = not na(mssBar) and bar_index - mssBar <= mssMaxAge

//------------------------------------------------------------------
// Liquidity sweeps + 4H FVG boundary touches (neutral-bias reversals)
//------------------------------------------------------------------
prevLo = ta.lowest(low, sweepLen)[1]
prevHi = ta.highest(high, sweepLen)[1]
sellSweep = low < prevLo and close > prevLo
buySweep  = high > prevHi and close < prevHi
var int sellSweepBar = na
var int buySweepBar = na
if sellSweep
    sellSweepBar := bar_index
if buySweep
    buySweepBar := bar_index
sellSweepRecent = not na(sellSweepBar) and bar_index - sellSweepBar <= revMaxAge
buySweepRecent  = not na(buySweepBar) and bar_index - buySweepBar <= revMaxAge

var int h4BullTouchBar = na
var int h4BearTouchBar = na
if not na(h4BullTop) and low <= h4BullTop
    h4BullTouchBar := bar_index
if not na(h4BearBot) and high >= h4BearBot
    h4BearTouchBar := bar_index
h4BullTouchRecent = not na(h4BullTouchBar) and bar_index - h4BullTouchBar <= revMaxAge
h4BearTouchRecent = not na(h4BearTouchBar) and bar_index - h4BearTouchBar <= revMaxAge

//------------------------------------------------------------------
// Kill zone
//------------------------------------------------------------------
inKZ = not na(time(timeframe.period, kzSess, "America/New_York"))
kzOk = not useKZ or inKZ
bgcolor(showKZ and inKZ ? color.new(color.blue, 94) : na)
dowOk = not dowFilter or dayofweek == dayofweek.tuesday or dayofweek == dayofweek.friday

//------------------------------------------------------------------
// Setup alignment (Steps 1-4 of the flagship model)
//------------------------------------------------------------------
neutralLongCtx  = useRev and h4Bias == 0 and h4BullTouchRecent and sellSweepRecent
neutralShortCtx = useRev and h4Bias == 0 and h4BearTouchRecent and buySweepRecent
nFallLongBase  = h4Bias == 0 and (neutralMode == "4H structure" and h4Struct == 1 or neutralMode == "15M flow")
nFallShortBase = h4Bias == 0 and (neutralMode == "4H structure" and h4Struct == -1 or neutralMode == "15M flow")
// Regime guard supersedes neutralLongOnly: long fallback only in an up regime,
// short fallback only in a down regime. Guard off = original static behaviour.
nFallLong  = nFallLongBase  and (useRegime ? regimeUp : true)
nFallShort = nFallShortBase and (useRegime ? not regimeUp : not neutralLongOnly)
biasOkLong  = h4Bias == 1 or neutralLongCtx or nFallLong
biasOkShort = h4Bias == -1 or neutralShortCtx or nFallShort
flowOkLong  = m15Flow == 1
flowOkShort = m15Flow == -1
mitOkLong   = m15BullMitAge >= 0 and m15BullMitAge <= mitMaxAge
mitOkShort  = m15BearMitAge >= 0 and m15BearMitAge <= mitMaxAge
setupLong  = biasOkLong and flowOkLong and mitOkLong and mssDir == 1 and mssRecent and (not sweepAll or sellSweepRecent)
setupShort = biasOkShort and flowOkShort and mitOkShort and mssDir == -1 and mssRecent and (not sweepAll or buySweepRecent)

//------------------------------------------------------------------
// 1M entry FVG (Step 5) + trigger on retrace into the zone
//------------------------------------------------------------------
atr14 = ta.atr(14)
dispOK = dispMult <= 0 or math.abs(close[1] - open[1]) >= dispMult * atr14[1]
newBullC = low > high[2] and dispOK
newBearC = high < low[2] and dispOK
var float eBullTop = na
var float eBullBot = na
var int   eBullBar = na
var bool  eBullDone = false
var float eBearTop = na
var float eBearBot = na
var int   eBearBar = na
var bool  eBearDone = false

if newBullC and setupLong
    eBullTop := low
    eBullBot := high[2]
    eBullBar := bar_index
    eBullDone := false
    if showEntryFvg
        box.new(bar_index - 2, low, bar_index + 20, high[2], border_color = color.new(color.teal, 35), bgcolor = color.new(color.teal, 85))
if newBearC and setupShort
    eBearTop := low[2]
    eBearBot := high
    eBearBar := bar_index
    eBearDone := false
    if showEntryFvg
        box.new(bar_index - 2, low[2], bar_index + 20, high, border_color = color.new(color.red, 35), bgcolor = color.new(color.red, 85))

if not na(eBullTop) and close < eBullBot
    eBullTop := na
    eBullBot := na
if not na(eBearTop) and close > eBearTop
    eBearTop := na
    eBearBot := na

armedLong  = setupLong and not na(eBullTop) and not eBullDone and kzOk and dowOk
armedShort = setupShort and not na(eBearTop) and not eBearDone and kzOk and dowOk

// entry trigger level: how deep into the 1M FVG price must trade before filling
// (0 = near edge / first tag, 1 = full fill at the far edge)
eBullTrig = not na(eBullTop) ? eBullTop - entryFrac * (eBullTop - eBullBot) : na
eBearTrig = not na(eBearTop) ? eBearBot + entryFrac * (eBearTop - eBearBot) : na

// volatility-scaled risk bounds: the point inputs above are the distances at
// refPrice; scaling by (close / refPrice) keeps them a constant % of price so the
// stop floor/cap/buffer stay meaningful at any price level (see useVolStop tooltip).
riskScale = useVolStop ? close / refPrice : 1.0
slBufR    = slBuf * riskScale
minRiskR  = minRisk * riskScale
maxRiskR  = maxRisk * riskScale

// planned stop / risk (swing-based) evaluated before the trigger
float slPlanL = (swingSL and not na(swingLoVal) ? math.min(eBullBot, swingLoVal) : eBullBot) - slBufR
float slPlanS = (swingSL and not na(swingHiVal) ? math.max(eBearTop, swingHiVal) : eBearTop) + slBufR
if minRiskR > 0 and not na(eBullTrig)
    slPlanL := math.min(slPlanL, eBullTrig - minRiskR)
if minRiskR > 0 and not na(eBearTrig)
    slPlanS := math.max(slPlanS, eBearTrig + minRiskR)
riskOkL = maxRiskR <= 0 or (not na(eBullTrig) and eBullTrig - slPlanL <= maxRiskR)
riskOkS = maxRiskR <= 0 or (not na(eBearTrig) and slPlanS - eBearTrig <= maxRiskR)

touchLong  = armedLong and bar_index > eBullBar and low <= eBullTrig
touchShort = armedShort and bar_index > eBearBar and high >= eBearTrig
barOk = not confirmBars or barstate.isconfirmed
longSignal  = touchLong and riskOkL and barOk
shortSignal = touchShort and riskOkS and barOk
if touchLong
    eBullDone := true
if touchShort
    eBearDone := true

// Entry / SL / TP plan drawn at the moment a signal fires
if longSignal and showPlan
    float tpL = eBullTrig + rrTarget * (eBullTrig - slPlanL)
    line.new(bar_index, eBullTrig, bar_index + 30, eBullTrig, color = color.gray, width = 1)
    line.new(bar_index, slPlanL, bar_index + 30, slPlanL, color = color.red, width = 1)
    line.new(bar_index, tpL, bar_index + 30, tpL, color = color.green, width = 1)
    label.new(bar_index + 30, tpL, "TP " + str.tostring(tpL, format.mintick) + "\nE  " + str.tostring(eBullTrig, format.mintick) + "\nSL " + str.tostring(slPlanL, format.mintick), style = label.style_label_left, color = color.new(color.green, 70), textcolor = color.white, size = size.small)
if shortSignal and showPlan
    float tpS = eBearTrig - rrTarget * (slPlanS - eBearTrig)
    line.new(bar_index, eBearTrig, bar_index + 30, eBearTrig, color = color.gray, width = 1)
    line.new(bar_index, slPlanS, bar_index + 30, slPlanS, color = color.red, width = 1)
    line.new(bar_index, tpS, bar_index + 30, tpS, color = color.green, width = 1)
    label.new(bar_index + 30, tpS, "TP " + str.tostring(tpS, format.mintick) + "\nE  " + str.tostring(eBearTrig, format.mintick) + "\nSL " + str.tostring(slPlanS, format.mintick), style = label.style_label_left, color = color.new(color.red, 70), textcolor = color.white, size = size.small)

plotshape(longSignal, title = "BUY", style = shape.triangleup, location = location.belowbar, color = color.new(color.green, 0), size = size.small, text = "BUY", textcolor = color.white)
plotshape(shortSignal, title = "SELL", style = shape.triangledown, location = location.abovebar, color = color.new(color.red, 0), size = size.small, text = "SELL", textcolor = color.white)

alertcondition(longSignal, "ICT Long Entry", "ICT NAS100: LONG - price tapped the 1M bullish FVG after MSS with 4H/15M alignment")
alertcondition(shortSignal, "ICT Short Entry", "ICT NAS100: SHORT - price tapped the 1M bearish FVG after MSS with 4H/15M alignment")

//------------------------------------------------------------------
// Active HTF zone boxes (updated on the last bar only)
//------------------------------------------------------------------
zoneBox(box b, float top, float bot, color c, string txt) =>
    box r = b
    if na(top) or na(bot)
        if not na(r)
            box.delete(r)
        r := na
    else
        left = math.max(bar_index - 60, 0)
        if na(r)
            r := box.new(left, top, bar_index + 10, bot, border_color = color.new(c, 40), bgcolor = color.new(c, 88), text = txt, text_color = color.new(c, 20), text_size = size.tiny, text_halign = text.align_left)
        else
            box.set_lefttop(r, left, top)
            box.set_rightbottom(r, bar_index + 10, bot)
    r

var box bH4Bull  = na
var box bH4Bear  = na
var box bM15Bull = na
var box bM15Bear = na
if barstate.islast and showZones
    bH4Bull := zoneBox(bH4Bull, h4BullTop, h4BullBot, color.green, "4H Bull FVG")
    bH4Bear := zoneBox(bH4Bear, h4BearTop, h4BearBot, color.red, "4H Bear FVG")
    bM15Bull := zoneBox(bM15Bull, m15BullTop, m15BullBot, color.teal, "15M Bull FVG")
    bM15Bear := zoneBox(bM15Bear, m15BearTop, m15BearBot, color.orange, "15M Bear FVG")

//------------------------------------------------------------------
// Status table (top right)
//------------------------------------------------------------------
var table tb = table.new(position.top_right, 2, 11, bgcolor = color.new(color.black, 15), frame_color = color.new(color.gray, 40), frame_width = 1, border_color = color.new(color.gray, 60), border_width = 1)

cBull = color.new(color.green, 0)
cBear = color.new(color.red, 0)
cMut  = color.new(color.gray, 0)

if showTable and barstate.islast
    biasTxt = h4Bias == 1 ? "Bullish" : h4Bias == -1 ? "Bearish" : nFallLong ? "Ntrl > Bull" : nFallShort ? "Ntrl > Bear" : "Neutral"
    biasCol = h4Bias == 1 or nFallLong ? cBull : h4Bias == -1 or nFallShort ? cBear : cMut
    flowTxt = m15Flow == 1 ? "Bullish" : m15Flow == -1 ? "Bearish" : "-"
    flowCol = m15Flow == 1 ? cBull : m15Flow == -1 ? cBear : cMut
    mitTxt = mitOkLong and mitOkShort ? "Bull+Bear" : mitOkLong ? "Bull FVG hit" : mitOkShort ? "Bear FVG hit" : "No"
    mitCol = mitOkLong and not mitOkShort ? cBull : mitOkShort and not mitOkLong ? cBear : cMut
    mssTxt = mssRecent and mssDir == 1 ? "Bullish" : mssRecent and mssDir == -1 ? "Bearish" : "-"
    mssCol = mssRecent and mssDir == 1 ? cBull : mssRecent and mssDir == -1 ? cBear : cMut
    fvgTxt = not na(eBullTop) and not eBullDone ? "Bull armed" : not na(eBearTop) and not eBearDone ? "Bear armed" : "-"
    fvgCol = not na(eBullTop) and not eBullDone ? cBull : not na(eBearTop) and not eBearDone ? cBear : cMut
    kzTxt = inKZ ? "ACTIVE" : "Closed"
    kzCol = inKZ ? cBull : cMut
    entryTxt = armedLong or longSignal ? "Long" : armedShort or shortSignal ? "Short" : "Wait"
    entryCol = armedLong or longSignal ? cBull : armedShort or shortSignal ? cBear : cMut
    typeTxt = armedLong or longSignal ? (h4Bias == 1 or nFallLong ? "Continuation" : "Reversal") : armedShort or shortSignal ? (h4Bias == -1 or nFallShort ? "Continuation" : "Reversal") : "-"
    sigTxt = longSignal ? "LONG NOW" : shortSignal ? "SHORT NOW" : armedLong ? "LONG SETUP" : armedShort ? "SHORT SETUP" : "WAIT"
    sigBg = longSignal or armedLong ? color.new(color.green, 25) : shortSignal or armedShort ? color.new(color.red, 25) : color.new(color.gray, 55)
    // first gate currently blocking a trade, in checklist order
    blockTxt = "-"
    if m15Flow == 0
        blockTxt := "15M flow flat"
    else if m15Flow == 1
        blockTxt := not biasOkLong ? "4H bias not bullish" : not mitOkLong ? "15M FVG not mitigated" : not (mssDir == 1 and mssRecent) ? "1M MSS not bullish" : sweepAll and not sellSweepRecent ? "No sell-side sweep" : na(eBullTop) or eBullDone ? "Waiting fresh 1M FVG" : not riskOkL ? "Stop outside limits" : not kzOk ? "Kill zone closed" : not dowOk ? "Excluded day (Tue/Fri only)" : "READY - await FVG tap"
    else
        blockTxt := not biasOkShort ? "4H bias not bearish" : not mitOkShort ? "15M FVG not mitigated" : not (mssDir == -1 and mssRecent) ? "1M MSS not bearish" : sweepAll and not buySweepRecent ? "No buy-side sweep" : na(eBearTop) or eBearDone ? "Waiting fresh 1M FVG" : not riskOkS ? "Stop outside limits" : not kzOk ? "Kill zone closed" : not dowOk ? "Excluded day (Tue/Fri only)" : "READY - await FVG tap"
    blockCol = str.startswith(blockTxt, "READY") ? cBull : color.new(color.orange, 0)

    table.cell(tb, 0, 0, "ICT NAS100", text_color = color.white, text_size = size.small, bgcolor = color.new(color.blue, 25))
    table.cell(tb, 1, 0, "TF " + timeframe.period, text_color = color.white, text_size = size.small, bgcolor = color.new(color.blue, 25))
    table.cell(tb, 0, 1, "4H Bias", text_color = color.silver, text_size = size.small)
    table.cell(tb, 1, 1, biasTxt, text_color = biasCol, text_size = size.small)
    table.cell(tb, 0, 2, "15M Flow", text_color = color.silver, text_size = size.small)
    table.cell(tb, 1, 2, flowTxt, text_color = flowCol, text_size = size.small)
    table.cell(tb, 0, 3, "15M FVG Mit", text_color = color.silver, text_size = size.small)
    table.cell(tb, 1, 3, mitTxt, text_color = mitCol, text_size = size.small)
    table.cell(tb, 0, 4, "1M MSS", text_color = color.silver, text_size = size.small)
    table.cell(tb, 1, 4, mssTxt, text_color = mssCol, text_size = size.small)
    table.cell(tb, 0, 5, "1M Entry FVG", text_color = color.silver, text_size = size.small)
    table.cell(tb, 1, 5, fvgTxt, text_color = fvgCol, text_size = size.small)
    table.cell(tb, 0, 6, "Kill Zone", text_color = color.silver, text_size = size.small)
    table.cell(tb, 1, 6, kzTxt, text_color = kzCol, text_size = size.small)
    table.cell(tb, 0, 7, "1M Entry", text_color = color.silver, text_size = size.small)
    table.cell(tb, 1, 7, entryTxt, text_color = entryCol, text_size = size.small)
    table.cell(tb, 0, 8, "Trade Type", text_color = color.silver, text_size = size.small)
    table.cell(tb, 1, 8, typeTxt, text_color = color.white, text_size = size.small)
    table.cell(tb, 0, 9, "Blocker", text_color = color.silver, text_size = size.small)
    table.cell(tb, 1, 9, blockTxt, text_color = blockCol, text_size = size.small)
    table.cell(tb, 0, 10, "SIGNAL", text_color = color.white, text_size = size.small, bgcolor = sigBg)
    table.cell(tb, 1, 10, sigTxt, text_color = color.white, text_size = size.small, bgcolor = sigBg)
